# ════════════════════════════════════════════════════════════════════
#  SELVERINE — Environment configuration
#  Copy to `.env` for local dev, or set these in EasyPanel → Environment.
#  NEVER commit a real .env (it is git-ignored). No secrets are hard-coded.
# ════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://selverine.com

# ── Database (SQLite via better-sqlite3) ─────────────────────────────
# Either DATABASE_URL=sqlite:/data/selverine.db  OR  DB_PATH=/data/selverine.db
# Point this at a PERSISTENT volume so orders survive redeploys.
DATABASE_URL=sqlite:/data/selverine.db
DB_PATH=/data/selverine.db

# ── Admin panel auth ─────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Plain password (hashed in-memory at boot). Use a long, unique value.
ADMIN_PASSWORD=change-me-to-a-strong-password
# Optional: provide a pre-computed bcrypt hash instead of ADMIN_PASSWORD.
# ADMIN_PASSWORD_HASH=

# ── Secrets (generate with: openssl rand -hex 32) ────────────────────
JWT_SECRET=replace-with-32+char-random-string
SESSION_SECRET=replace-with-32+char-random-string
WEBHOOK_SECRET=replace-with-32+char-random-string

# ── Facebook / Meta Pixel (browser) ──────────────────────────────────
# If set, the Pixel is auto-injected into every page (PageView + events).
FACEBOOK_PIXEL_ID=999090572948619

# ── Meta Conversion API (server-side) ────────────────────────────────
# META_PIXEL_ID defaults to FACEBOOK_PIXEL_ID if omitted.
META_PIXEL_ID=999090572948619
META_ACCESS_TOKEN=your-meta-conversions-api-access-token
# Optional — only while testing in Events Manager → Test Events.
META_TEST_EVENT_CODE=
META_API_VERSION=v19.0

# ── Product defaults (used for Pixel/CAPI value + contents) ──────────
PRODUCT_NAME=SELVERINE
PRODUCT_ID=selverine-hair-oil
CURRENCY=MAD
DEFAULT_COUNTRY=MA

# ── Optional outbound webhook (fired on order.created) ───────────────
# OUTBOUND_WEBHOOK_URL=https://example.com/hooks/selverine
